---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '敲码小站',
  description = '敲码人的个人学习工作台：记录笔记、整理项目、持续进步。',
} = Astro.props;

const pathname = Astro.url.pathname;
const nav = [
  { href: '/', label: '工作台' },
  { href: '/tools/', label: '工具' },
  { href: '/blog/', label: '笔记' },
  { href: '/projects/', label: '项目' },
  { href: '/about/', label: '关于' },
];

function isCurrent(href: string) {
  if (href === '/') return pathname === '/' || pathname === '';
  if (href === '/tools/') {
    return pathname.startsWith('/tools/') || pathname.startsWith('/todo/');
  }
  return pathname === href || pathname.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=ZCOOL+XiaoWei&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-wrap site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark" aria-hidden="true"></span>
          敲码小站
        </a>
        <nav aria-label="主导航">
          <ul class="nav">
            {
              nav.map((item) => (
                <li>
                  <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="site-wrap">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-wrap site-footer__inner">
        <span>© {new Date().getFullYear()} 敲码人 · 敲码小站</span>
        <a href="https://github.com/mwzzz" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>
