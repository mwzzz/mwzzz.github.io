---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageTitle, site } from '../data/site';
---

<BaseLayout title={pageTitle('关于')} description={`关于 ${site.name}。`}>
  <header class="page-intro">
    <h1>关于</h1>
    <p>Software Engineer · 用写作把学习变成可复用的资产。</p>
  </header>

  <article class="prose">
    <p>
      <strong>{site.name}</strong> 是我的个人学习工作台：记录技术笔记、整理进行中的项目，也偶尔写下学习方法。
    </p>
    <p>
      If you wish to succeed, you should use persistence as your good friend, experience as your
      reference, prudence as your brother and hope as your sentry.
    </p>
    <p>
      代码与站点托管在
      <a href="https://github.com/mwzzz" target="_blank" rel="noopener noreferrer">GitHub @mwzzz</a>。
    </p>
  </article>
</BaseLayout>
